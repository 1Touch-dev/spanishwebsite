# API-Football CMS proxy (primary source for matches/standings/topscorers).
# The proxy stores the API-Football key on the backend, so this app sends
# no auth header. Defaults to https://api.labenditaec.com/api/football when unset.
FOOTBALL_API_BASE_URL=
# Default season passed to API-Football endpoints (year of season start).
FOOTBALL_API_SEASON=2025

# Football-Data.org API token (optional fallback for La Liga data when the
# CMS proxy is unreachable). Free tier — register at:
# https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# Site URL (used for SEO, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://futhoy.com
